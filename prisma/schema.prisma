generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseAccessType {
  FREE
  PAID
  PRIVATE
}

enum LessonType {
  REGULAR
  ASSIGNMENT
  TEST
  WEBINAR
}

enum LessonStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  REVOKED
}

enum EnrollmentAccessSource {
  FREE
  PURCHASE
  MANUAL
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

enum PaymentEventType {
  RESULT
  SUCCESS
  FAIL
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String
  role          UserRole   @default(USER)
  ownedCourses  Course[]   @relation("CourseOwner")
  enrollments   Enrollment[]
  orders        Order[]
  progress      LessonProgress[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Course {
  id                String         @id @default(cuid())
  title             String
  slug              String         @unique
  shortDescription  String?
  description       String?
  coverImageUrl     String?
  status            CourseStatus   @default(DRAFT)
  accessType        CourseAccessType @default(PAID)
  priceAmount       Int?
  ownerId           String?
  owner             User?          @relation("CourseOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  modules           CourseModule[]
  enrollments       Enrollment[]
  orders            Order[]
  publishedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([status])
  @@index([accessType])
  @@index([ownerId])
}

model Order {
  id        Int           @id @default(autoincrement())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course        @relation(fields: [courseId], references: [id], onDelete: Restrict)
  status    OrderStatus   @default(PENDING)
  amount    Int
  currency  String        @default("RUB")
  paidAt    DateTime?
  events    PaymentEvent[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([userId, courseId, status])
  @@index([userId, status])
  @@index([courseId, status])
}

model PaymentEvent {
  id             String            @id @default(cuid())
  orderId        Int
  order          Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventType      PaymentEventType
  signatureValue  String
  payload        Json
  verified       Boolean           @default(false)
  receivedAt     DateTime          @default(now())
  processedAt    DateTime?

  @@unique([orderId, eventType, signatureValue])
  @@index([orderId, eventType])
}

model CourseModule {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  sortOrder   Int
  published   Boolean  @default(false)
  publishedAt DateTime?
  lessons     Lesson[]

  @@index([courseId, sortOrder])
}

model Lesson {
  id          String      @id @default(cuid())
  moduleId    String
  module      CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  sortOrder   Int
  lessonType  LessonType
  status      LessonStatus @default(DRAFT)
  preview     Boolean      @default(false)
  summary     String?
  content     Json?
  publishedAt DateTime?
  progress    LessonProgress[]

  @@unique([moduleId, slug])
  @@index([moduleId, sortOrder])
  @@index([lessonType])
  @@index([status])
}

model Enrollment {
  id          String                 @id @default(cuid())
  userId      String
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status      EnrollmentStatus       @default(ACTIVE)
  accessSource EnrollmentAccessSource
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@unique([userId, courseId])
  @@index([courseId, status])
  @@index([userId, status])
}

model LessonProgress {
  id              String               @id @default(cuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId        String
  lesson          Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status          LessonProgressStatus @default(NOT_STARTED)
  progressPercent Int                  @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([userId, lessonId])
  @@index([lessonId, status])
  @@index([userId, status])
}
